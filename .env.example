PORT=3032
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_DATABASE_PASSWORD=
DATABASE_URL=

# AI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=

# Lead research defaults
LEAD_RESEARCH_DEFAULT_STATE=PA
LEAD_RESEARCH_DEFAULT_CITY=Philadelphia
LEAD_RESEARCH_BUSINESS_TZ=America/New_York
CRON_SECRET=

# Google Maps scrape
GOOGLE_MAPS_API_KEY=

# Gmail (Workspace service account — see src/services/email/README.md)
# Local dev: save GCP key as a file and use PATH (avoids .env quoting issues)
GMAIL_SERVICE_ACCOUNT_JSON_PATH=
# Or one-line minified JSON (do not set BASE64 if you use these)
GMAIL_SERVICE_ACCOUNT_JSON=
GMAIL_SERVICE_ACCOUNT_JSON_BASE64=
GMAIL_SEND_AS_EMAIL=
GMAIL_FROM_NAME=Lead Studio
GMAIL_PUBSUB_TOPIC=
# Public HTTPS URL of this server (required for open pixels; mail clients cannot reach localhost)
EMAIL_OPEN_TRACKING_BASE_URL=
# Optional: 302 redirect instead of 1×1 GIF response
EMAIL_OPEN_TRACKING_REDIRECT_URL=

# Facebook scrapers (Apify / n8n)
APIFY_API_TOKEN=
SCRAPER_FACEBOOK_PAGE_DETAILS_TIMEOUT_MS=300000
SCRAPER_FACEBOOK_POSTS_WEBHOOK_URL=
SCRAPER_FACEBOOK_POSTS_TIMEOUT_MS=120000

# Email queue
LEAD_EMAIL_QUEUE_MIDDAY_PAUSE_ENABLED=true

# Postgres pool
PG_POOL_MAX=10
